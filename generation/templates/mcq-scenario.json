  "code": "se-arch-caching-scenario-mcq",
  "name": "Cache Eviction Scenario MCQ",
  "templateType": "scenario-based",
  "topicId": "se-arch-002",
  "conceptId": "Caching Strategies",
  "difficulty": "medium",
  "templateText": "Your backend service processes {REQUESTS_PER_SECOND} requests/second. The database access time is {DB_LATENCY_MS}ms. You introduce a Redis cache with a read latency of {CACHE_LATENCY_MS}ms. If your cache hit rate is {HIT_RATE_PERCENT}%, what is the average database latency per request (excluding cache lookup time on miss)?",
  "variables": [
    {
      "variableName": "REQUESTS_PER_SECOND",
      "variableType": "number",
      "required": true,
      "constraints": {
        "choices": [1000, 5000, 10000]
      }
    },
    {
      "variableName": "DB_LATENCY_MS",
      "variableType": "number",
      "required": true,
      "constraints": {
        "min": 50,
        "max": 200
      }
    },
    {
      "variableName": "CACHE_LATENCY_MS",
      "variableType": "number",
      "required": true,
      "constraints": {
        "min": 1,
        "max": 5
      }
    },
    {
      "variableName": "HIT_RATE_PERCENT",
      "variableType": "number",
      "required": true,
      "constraints": {
        "choices": [70, 80, 90]
      }
    }
  ],
