{
  "name": "intervu-ai",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "generation"
  ],
  "prisma": {
    "seed": "tsx packages/database/prisma/seed/index.ts"
  },
  "scripts": {
    "postinstall": "npm run prisma:generate --workspace @intervu-ai/database",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier . --write",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:day3": "turbo run test:day3",
    "test:integration": "turbo run test:integration",
    "test:contracts": "turbo run test:contracts",
    "test:regression": "turbo run test:regression",
    "check:structure": "node scripts/check-structure.js",
    "generate:test": "tsx scripts/test-generation.ts",
    "verify:day2": "tsx scripts/verify-day2.ts",
    "verify:day3": "tsx scripts/verify-day3.ts",
    "verify:day4": "node --import tsx --env-file=apps/api/.env scripts/verify-day4.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-util": "^30.4.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "shared-logger": "^1.0.12"
  }
}
