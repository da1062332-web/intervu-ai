{
  "info": {
    "name": "InterVu AI - Day 5 Results",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Results",
      "item": [
        {
          "name": "Get Evaluation Result Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/results/{{evaluationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "results", "{{evaluationId}}"]
            }
          }
        },
        {
          "name": "Get Evaluation Recommendations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/results/{{evaluationId}}/recommendations",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "results", "{{evaluationId}}", "recommendations"]
            }
          }
        }
      ]
    },
    {
      "name": "Performance",
      "item": [
        {
          "name": "Get Performance Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/users/me/performance-summary",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "me", "performance-summary"]
            }
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/users/me/history?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "me", "history"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
