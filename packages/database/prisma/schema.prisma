generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  role         UserRole @default(CANDIDATE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions           Session[]
  refreshTokens      RefreshToken[]
  templates          Template[]
  tests              Test[]
  testInstances      TestInstance[]
  evaluationResults  EvaluationResult[]
  performanceSummary PerformanceSummary?

  @@index([deletedAt])
  @@index([role])
}

model Session {
  id        String  @id @default(cuid())
  userId    String
  userAgent String?
  ipAddress String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id     String @id @default(cuid())
  token  String @unique
  userId String

  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model Template {
  id              String          @id @default(cuid())
  templateKey     String          @unique @default(cuid())
  conceptKey      String          @default("default_concept")
  difficultyLevel DifficultyLevel @default(MEDIUM)
  questionType    String          @default("multiple_choice")
  structure       Json            @default("{}")
  variableSchema  Json            @default("{}")
  constraints     Json            @default("{}")
  solutionSchema  Json            @default("{}")
  version         Int             @default(1)
  isActive        Boolean         @default(true)

  name        String          @default("Legacy Template")
  description String?
  difficulty  DifficultyLevel @default(MEDIUM)
  config      Json            @default("{}")
  isSystem    Boolean         @default(false)
  creatorId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  creator            User?               @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  tests              Test[]
  generatedQuestions GeneratedQuestion[]

  @@index([templateKey])
  @@index([conceptKey])
  @@index([difficultyLevel])
  @@index([creatorId])
  @@index([difficulty])
  @@index([isSystem])
  @@index([deletedAt])
}

model Test {
  id          String     @id @default(cuid())
  templateId  String
  userId      String
  status      TestStatus @default(DRAFT)
  score       Float?
  feedback    String?
  answers     Json?
  questions   Json?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  template         Template          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluationResult EvaluationResult?

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@index([deletedAt])
}

enum UserRole {
  CANDIDATE
  ADMIN
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum TestStatus {
  DRAFT
  ONGOING
  COMPLETED
  EVALUATED
  FAILED
}

model SystemConfig {
  id        String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationResult {
  id                 String   @id @default(cuid())
  testId             String?  @unique
  testInstanceId     String?  @unique
  userId             String
  communicationScore Float    @default(0.0)
  technicalScore     Float    @default(0.0)
  confidenceScore    Float
  overallScore       Float
  overallRating      Float    @default(0.0)
  notes              String?
  totalQuestions     Int      @default(0)
  correctAnswers     Int      @default(0)
  incorrectAnswers   Int      @default(0)
  evaluatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  test            Test?            @relation(fields: [testId], references: [id], onDelete: Cascade)
  testInstance    TestInstance?    @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillScores     SkillScore[]
  recommendations Recommendation[]

  @@index([userId])
  @@index([testId])
  @@index([testInstanceId])
  @@index([overallScore])
  @@index([createdAt])
}

model SkillScore {
  id           String   @id @default(cuid())
  evaluationId String
  skill        String
  score        Float
  feedback     String
  createdAt    DateTime @default(now())

  evaluation EvaluationResult @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model TestConfig {
  id                   String   @id @default(cuid())
  configKey            String   @unique
  companyName          String
  displayName          String
  totalDurationSeconds Int
  totalQuestions       Int
  isActive             Boolean  @default(true)
  version              Int      @default(1)
  createdAt            DateTime @default(now())

  sections      TestSection[]
  rule          TestRule?
  testInstances TestInstance[]

  @@index([configKey])
}

model TestSection {
  id              String @id @default(cuid())
  testConfigId    String
  sectionKey      String
  displayName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int

  testConfig TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)

  @@index([testConfigId])
}

model TestRule {
  id               String  @id @default(cuid())
  testConfigId     String  @unique
  negativeMarking  Boolean @default(false)
  sectionLocking   Boolean @default(true)
  shuffleQuestions Boolean @default(false)
  allowNavigation  Boolean @default(false)

  testConfig TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)
}

model GeneratedQuestion {
  id              String          @id @default(cuid())
  templateId      String
  questionHash    String          @unique
  conceptKey      String
  difficultyLevel DifficultyLevel
  questionType    String
  questionText    String
  options         Json
  correctAnswer   Json
  solution        Json
  metadata        Json
  createdAt       DateTime        @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([conceptKey])
  @@index([difficultyLevel])
}

enum TestInstanceStatus {
  CREATED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

model TestInstance {
  id           String             @id @default(cuid())
  userId       String
  testConfigId String
  status       TestInstanceStatus @default(CREATED)
  startedAt    DateTime?
  expiresAt    DateTime?
  submittedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  testConfig       TestConfig             @relation(fields: [testConfigId], references: [id], onDelete: Restrict)
  sections         TestInstanceSection[]
  questions        TestInstanceQuestion[]
  candidateAnswers CandidateAnswer[]
  executionState   ExecutionState?
  submission       Submission?
  evaluationResult EvaluationResult?

  @@index([userId])
  @@index([status])
  @@index([testConfigId])
  @@index([createdAt])
}

model TestInstanceSection {
  id              String   @id @default(cuid())
  testInstanceId  String
  sectionKey      String
  sectionName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  testInstance TestInstance           @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)
  questions    TestInstanceQuestion[]

  @@unique([testInstanceId, orderIndex])
  @@index([testInstanceId])
}

model TestInstanceQuestion {
  id               String   @id @default(cuid())
  testInstanceId   String
  sectionId        String
  questionId       String
  questionOrder    Int
  questionSnapshot Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  testInstance TestInstance        @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)
  section      TestInstanceSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, questionOrder])
  @@index([testInstanceId])
  @@index([sectionId])
  @@index([questionId])
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  EVALUATED
}

model CandidateAnswer {
  id                String   @id @default(cuid())
  testInstanceId    String
  questionId        String
  answer            Json
  timeSpentSeconds  Int      @default(0)
  isMarkedForReview Boolean  @default(false)
  savedAt           DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  testInstance TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([testInstanceId, questionId])
  @@index([testInstanceId])
  @@index([questionId])
}

model ExecutionState {
  id                   String   @id @default(cuid())
  testInstanceId       String   @unique
  currentQuestionIndex Int      @default(0)
  remainingTimeSeconds Int
  lastActivityAt       DateTime @default(now())
  updatedAt            DateTime @updatedAt

  testInstance TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
}

model Submission {
  id             String           @id @default(cuid())
  testInstanceId String           @unique
  submittedAt    DateTime?
  submissionHash String?          @unique
  status         SubmissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  testInstance TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
  @@index([status])
}

enum RecommendationPriority {
  HIGH
  MEDIUM
  LOW
}

model Recommendation {
  id           String                 @id @default(cuid())
  evaluationId String
  skill        String
  priority     RecommendationPriority
  title        String
  description  String
  createdAt    DateTime               @default(now())

  evaluation EvaluationResult @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([priority])
}

model PerformanceSummary {
  id                 String    @id @default(cuid())
  userId             String    @unique
  testsCompleted     Int       @default(0)
  averageScore       Float     @default(0.0)
  bestScore          Float     @default(0.0)
  lastAssessmentDate DateTime?
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamConfig {
  id              String   @id @default(cuid())
  name            String
  role            String
  durationMinutes Int
  totalQuestions  Int
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions               ExamConfigVersion[]
  difficultyDistribution DifficultyDistribution?
  ruleFlags              ExamRuleFlags?
  sections               ExamSection[]

  @@index([createdAt])
  @@index([role])
}

model ExamSection {
  id              String     @id @default(cuid())
  examConfigId    String
  name            String
  questionCount   Int
  durationMinutes Int?
  displayOrder    Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  examConfig      ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@unique([examConfigId, displayOrder])
  @@index([examConfigId])
  @@index([displayOrder])
}

model DifficultyDistribution {
  id             String   @id @default(cuid())
  examConfigId   String   @unique
  easyCount      Int
  mediumCount    Int
  hardCount      Int
  totalQuestions Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  examConfig ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}

model ExamConfigVersion {
  id            String   @id @default(cuid())
  examConfigId  String
  versionNumber Int
  snapshot      Json
  createdAt     DateTime @default(now())

  examConfig ExamConfig @relation(fields: [examConfigId], references: [id])

  @@unique([examConfigId, versionNumber])
  @@index([examConfigId])
}

model ExamRuleFlags {
  id                     String   @id @default(cuid())
  examConfigId           String   @unique
  negativeMarkingEnabled Boolean  @default(false)
  randomizeQuestions     Boolean  @default(false)
  randomizeOptions       Boolean  @default(false)
  calculatorAllowed      Boolean  @default(false)
  sectionLockingEnabled  Boolean  @default(false)
  freeNavigationEnabled  Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  examConfig ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}
