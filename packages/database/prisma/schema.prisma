generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String?
  role               UserRole            @default(CANDIDATE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  evaluationResults  EvaluationResult[]
  performanceSummary PerformanceSummary?
  refreshTokens      RefreshToken[]
  sessions           Session[]
  templates          Template[]
  tests              Test[]
  testInstances      TestInstance[]

  @@index([deletedAt])
  @@index([role])
}

model Session {
  id            String         @id @default(cuid())
  userId        String
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime       @default(now())
  expiresAt     DateTime
  refreshTokens RefreshToken[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model Template {
  id                 String              @id @default(cuid())
  templateKey        String              @unique @default(cuid())
  conceptKey         String              @default("default_concept")
  difficultyLevel    DifficultyLevel     @default(MEDIUM)
  questionType       String              @default("multiple_choice")
  structure          Json                @default("{}")
  variableSchema     Json                @default("{}")
  constraints        Json                @default("{}")
  solutionSchema     Json                @default("{}")
  version            Int                 @default(1)
  isActive           Boolean             @default(true)
  name               String              @default("Legacy Template")
  description        String?
  difficulty         DifficultyLevel     @default(MEDIUM)
  config             Json                @default("{}")
  isSystem           Boolean             @default(false)
  creatorId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  generatedQuestions GeneratedQuestion[]
  creator            User?               @relation(fields: [creatorId], references: [id])
  tests              Test[]

  @@index([templateKey])
  @@index([conceptKey])
  @@index([difficultyLevel])
  @@index([creatorId])
  @@index([difficulty])
  @@index([isSystem])
  @@index([deletedAt])
}

model Test {
  id               String            @id @default(cuid())
  templateId       String
  userId           String
  status           TestStatus        @default(DRAFT)
  score            Float?
  feedback         String?
  answers          Json?
  questions        Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  evaluationResult EvaluationResult?
  template         Template          @relation(fields: [templateId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@index([deletedAt])
}

model SystemConfig {
  id        String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationResult {
  id                 String           @id @default(cuid())
  testId             String?          @unique
  userId             String
  communicationScore Float            @default(0.0)
  technicalScore     Float            @default(0.0)
  confidenceScore    Float
  overallScore       Float
  overallRating      Float            @default(0.0)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  correctAnswers     Int              @default(0)
  evaluatedAt        DateTime         @default(now())
  incorrectAnswers   Int              @default(0)
  testInstanceId     String?          @unique
  totalQuestions     Int              @default(0)
  test               Test?            @relation(fields: [testId], references: [id], onDelete: Cascade)
  testInstance       TestInstance?    @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations    Recommendation[]
  skillScores        SkillScore[]

  @@index([userId])
  @@index([testId])
  @@index([testInstanceId])
  @@index([overallScore])
  @@index([createdAt])
}

model SkillScore {
  id           String           @id @default(cuid())
  evaluationId String
  skill        String
  score        Float
  feedback     String
  createdAt    DateTime         @default(now())
  evaluation   EvaluationResult @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model TestConfig {
  id                   String         @id @default(cuid())
  configKey            String         @unique
  companyName          String
  displayName          String
  totalDurationSeconds Int
  totalQuestions       Int
  isActive             Boolean        @default(true)
  version              Int            @default(1)
  createdAt            DateTime       @default(now())
  testInstances        TestInstance[]
  rule                 TestRule?
  sections             TestSection[]

  @@index([configKey])
}

model TestSection {
  id              String     @id @default(cuid())
  testConfigId    String
  sectionKey      String
  displayName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int
  testConfig      TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)

  @@index([testConfigId])
}

model TestRule {
  id               String     @id @default(cuid())
  testConfigId     String     @unique
  negativeMarking  Boolean    @default(false)
  sectionLocking   Boolean    @default(true)
  shuffleQuestions Boolean    @default(false)
  allowNavigation  Boolean    @default(false)
  testConfig       TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)
}

model GeneratedQuestion {
  id              String          @id @default(cuid())
  templateId      String
  questionHash    String          @unique
  conceptKey      String
  difficultyLevel DifficultyLevel
  questionType    String
  questionText    String
  options         Json
  correctAnswer   Json
  solution        Json
  metadata        Json
  createdAt       DateTime        @default(now())
  template        Template        @relation(fields: [templateId], references: [id])

  @@index([conceptKey])
  @@index([difficultyLevel])
}

model TestInstance {
  id               String                 @id @default(cuid())
  userId           String
  testConfigId     String
  status           TestInstanceStatus     @default(CREATED)
  startedAt        DateTime?
  expiresAt        DateTime?
  submittedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  candidateAnswers CandidateAnswer[]
  evaluationResult EvaluationResult?
  executionState   ExecutionState?
  submission       Submission?
  testConfig       TestConfig             @relation(fields: [testConfigId], references: [id])
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions        TestInstanceQuestion[]
  sections         TestInstanceSection[]

  @@index([userId])
  @@index([status])
  @@index([testConfigId])
  @@index([createdAt])
}

model TestInstanceSection {
  id              String                 @id @default(cuid())
  testInstanceId  String
  sectionKey      String
  sectionName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  questions       TestInstanceQuestion[]
  testInstance    TestInstance           @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([testInstanceId, orderIndex])
  @@index([testInstanceId])
}

model TestInstanceQuestion {
  id               String              @id @default(cuid())
  testInstanceId   String
  sectionId        String
  questionId       String
  questionOrder    Int
  questionSnapshot Json
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  section          TestInstanceSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  testInstance     TestInstance        @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([sectionId, questionOrder])
  @@index([testInstanceId])
  @@index([sectionId])
  @@index([questionId])
}

model CandidateAnswer {
  id                String       @id @default(cuid())
  testInstanceId    String
  questionId        String
  answer            Json
  timeSpentSeconds  Int          @default(0)
  isMarkedForReview Boolean      @default(false)
  savedAt           DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  testInstance      TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([testInstanceId, questionId])
  @@index([testInstanceId])
  @@index([questionId])
}

model ExecutionState {
  id                   String       @id @default(cuid())
  testInstanceId       String       @unique
  currentQuestionIndex Int          @default(0)
  remainingTimeSeconds Int
  lastActivityAt       DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  testInstance         TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
}

model Submission {
  id             String           @id @default(cuid())
  testInstanceId String           @unique
  submittedAt    DateTime?
  submissionHash String?          @unique
  status         SubmissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  testInstance   TestInstance     @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
  @@index([status])
}

model Recommendation {
  id           String                 @id @default(cuid())
  evaluationId String
  skill        String
  priority     RecommendationPriority
  title        String
  description  String
  createdAt    DateTime               @default(now())
  evaluation   EvaluationResult       @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([priority])
}

model PerformanceSummary {
  id                 String    @id @default(cuid())
  userId             String    @unique
  testsCompleted     Int       @default(0)
  averageScore       Float     @default(0.0)
  bestScore          Float     @default(0.0)
  lastAssessmentDate DateTime?
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamConfig {
  id                     String                  @id @default(cuid())
  name                   String
  role                   String
  durationMinutes        Int
  totalQuestions         Int
  isActive               Boolean                 @default(true)
  createdBy              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  code                   String                  @unique
  description            String?
  isArchived             Boolean                 @default(false)
  status                 ConfigStatus            @default(DRAFT)
  difficultyDistribution DifficultyDistribution?
  versions               ExamConfigVersion[]
  ruleFlags              ExamRuleFlags?
  sections               ExamSection[]
  blueprints             blueprints?

  @@index([createdAt])
  @@index([role])
}

model ExamSection {
  id                      String                    @id @default(cuid())
  examConfigId            String
  name                    String
  questionCount           Int
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  code                    String
  isRequired              Boolean                   @default(true)
  sectionDurationMinutes  Int
  sectionOrder            Int
  examConfig              ExamConfig                @relation(fields: [examConfigId], references: [id], onDelete: Cascade)
  blueprint_topic_configs blueprint_topic_configs[]
  sectionTopics           SectionTopic[]

  @@unique([examConfigId, code])
  @@index([examConfigId])
  @@index([sectionOrder])
}

model DifficultyDistribution {
  id             String     @id @default(cuid())
  examConfigId   String     @unique
  easyCount      Int
  mediumCount    Int
  hardCount      Int
  totalQuestions Int
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  examConfig     ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}

model ExamConfigVersion {
  id            String     @id @default(cuid())
  examConfigId  String
  versionNumber Int
  snapshot      Json
  createdAt     DateTime   @default(now())
  examConfig    ExamConfig @relation(fields: [examConfigId], references: [id])

  @@unique([examConfigId, versionNumber])
  @@index([examConfigId])
}

model ExamRuleFlags {
  id                     String     @id @default(cuid())
  examConfigId           String     @unique
  negativeMarkingEnabled Boolean    @default(false)
  randomizeQuestions     Boolean    @default(false)
  randomizeOptions       Boolean    @default(false)
  calculatorAllowed      Boolean    @default(false)
  sectionLockingEnabled  Boolean    @default(false)
  freeNavigationEnabled  Boolean    @default(true)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  examConfig             ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}

model Topic {
  id                      String                    @id @default(cuid())
  domain                  String
  topicName               String
  subtopic                String
  tags                    String[]
  easySupport             Boolean                   @default(true)
  mediumSupport           Boolean                   @default(true)
  hardSupport             Boolean                   @default(true)
  isActive                Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?
  conceptMappings         ConceptMapping[]
  blueprint_topic_configs blueprint_topic_configs[]
  sectionTopics           SectionTopic[]
}

model ConceptMapping {
  id          String    @id @default(cuid())
  topicId     String
  conceptName String
  conceptCode String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  topic       Topic     @relation(fields: [topicId], references: [id])

  @@unique([topicId, conceptCode])
  @@index([topicId])
}

model SectionTopic {
  id        String   @id @default(cuid())
  sectionId String
  topicId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section        ExamSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  topic          Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicWeightage TopicWeightage?

  @@unique([sectionId, topicId])
  @@index([sectionId])
  @@index([topicId])
}

model TopicWeightage {
  id                  String   @id @default(cuid())
  sectionId           String
  topicId             String
  weightagePercentage Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sectionTopic        SectionTopic @relation(fields: [sectionId, topicId], references: [sectionId, topicId], onDelete: Cascade)

  @@unique([sectionId, topicId])
  @@index([sectionId])
  @@index([topicId])
}

model blueprint_configs {
  id                      String                    @id
  name                    String
  code                    String                    @unique
  description             String?
  totalQuestions          Int
  totalDurationMinutes    Int
  isActive                Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  deletedAt               DateTime?
  blueprint_topic_configs blueprint_topic_configs[]

  @@index([deletedAt])
}

model blueprint_topic_configs {
  id                String            @id
  blueprintId       String
  sectionId         String
  topicId           String
  questionCount     Int
  weightage         Decimal
  easyCount         Int
  mediumCount       Int
  hardCount         Int
  createdAt         DateTime          @default(now())
  blueprint_configs blueprint_configs @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  ExamSection       ExamSection       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  Topic             Topic             @relation(fields: [topicId], references: [id])

  @@unique([blueprintId, topicId])
  @@index([blueprintId])
  @@index([sectionId])
  @@index([topicId])
}

model blueprints {
  id               String         @id
  config_id        String         @unique
  style_profile_id String
  sections         Json
  created_at       DateTime       @default(now())
  updated_at       DateTime
  ExamConfig       ExamConfig     @relation(fields: [config_id], references: [id], onDelete: Cascade)
  style_profiles   style_profiles @relation(fields: [style_profile_id], references: [id])

  @@index([config_id])
  @@index([style_profile_id])
}

model style_profile_characteristics {
  id                   String         @id
  profile_id           String
  characteristic_name  String
  characteristic_value Json
  created_at           DateTime       @default(now())
  updated_at           DateTime
  style_profiles       style_profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, characteristic_name])
  @@index([profile_id])
}

model style_profiles {
  id                            String                          @id
  name                          String
  profile_type                  String
  description                   String?
  active                        Boolean                         @default(true)
  created_at                    DateTime                        @default(now())
  updated_at                    DateTime
  blueprints                    blueprints[]
  style_profile_characteristics style_profile_characteristics[]

  @@index([active])
  @@index([profile_type])
}

enum UserRole {
  CANDIDATE
  ADMIN
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum TestStatus {
  DRAFT
  ONGOING
  COMPLETED
  EVALUATED
  FAILED
}

enum TestInstanceStatus {
  CREATED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  EVALUATED
}

enum RecommendationPriority {
  HIGH
  MEDIUM
  LOW
}

enum ConfigStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}
