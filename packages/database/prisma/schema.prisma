generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String?
  role               UserRole            @default(CANDIDATE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  evaluationResults  EvaluationResult[]
  performanceSummary PerformanceSummary?
  refreshTokens      RefreshToken[]
  sessions           Session[]
  templates          Template[]
  tests              Test[]
  testInstances      TestInstance[]

  @@index([deletedAt])
  @@index([role])
}

model Session {
  id            String         @id @default(cuid())
  userId        String
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime       @default(now())
  expiresAt     DateTime
  refreshTokens RefreshToken[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model Template {
  id                 String              @id @default(cuid())
  templateKey        String              @unique @default(cuid())
  conceptKey         String              @default("default_concept")
  difficultyLevel    DifficultyLevel     @default(MEDIUM)
  questionType       String              @default("multiple_choice")
  structure          Json                @default("{}")
  variableSchema     Json                @default("{}")
  constraints        Json                @default("{}")
  solutionSchema     Json                @default("{}")
  version            Int                 @default(1)
  isActive           Boolean             @default(true)
  name               String              @default("Legacy Template")
  description        String?
  difficulty         DifficultyLevel     @default(MEDIUM)
  config             Json                @default("{}")
  isSystem           Boolean             @default(false)
  creatorId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  generatedQuestions GeneratedQuestion[]
  questions          Question[]
  creator            User?               @relation(fields: [creatorId], references: [id])
  tests              Test[]
  variables          TemplateVariable[]
  rules              TemplateRule[]
  solutionTemplate   SolutionTemplate?
  previews           TemplatePreview[]

  @@index([templateKey])
  @@index([conceptKey])
  @@index([difficultyLevel])
  @@index([creatorId])
  @@index([difficulty])
  @@index([isSystem])
  @@index([deletedAt])
}

model Test {
  id               String            @id @default(cuid())
  templateId       String
  userId           String
  status           TestStatus        @default(DRAFT)
  score            Float?
  feedback         String?
  answers          Json?
  questions        Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  evaluationResult EvaluationResult?
  template         Template          @relation(fields: [templateId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@index([deletedAt])
}

model SystemConfig {
  id        String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationResult {
  id                 String           @id @default(cuid())
  testId             String?          @unique
  userId             String
  communicationScore Float            @default(0.0)
  technicalScore     Float            @default(0.0)
  confidenceScore    Float
  overallScore       Float
  overallRating      Float            @default(0.0)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  correctAnswers     Int              @default(0)
  evaluatedAt        DateTime         @default(now())
  incorrectAnswers   Int              @default(0)
  testInstanceId     String?          @unique
  totalQuestions     Int              @default(0)
  test               Test?            @relation(fields: [testId], references: [id], onDelete: Cascade)
  testInstance       TestInstance?    @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations    Recommendation[]
  skillScores        SkillScore[]

  @@index([userId])
  @@index([testId])
  @@index([testInstanceId])
  @@index([overallScore])
  @@index([createdAt])
}

model SkillScore {
  id           String           @id @default(cuid())
  evaluationId String
  skill        String
  score        Float
  feedback     String
  createdAt    DateTime         @default(now())
  evaluation   EvaluationResult @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model TestConfig {
  id                   String         @id @default(cuid())
  configKey            String         @unique
  companyName          String
  displayName          String
  totalDurationSeconds Int
  totalQuestions       Int
  isActive             Boolean        @default(true)
  version              Int            @default(1)
  createdAt            DateTime       @default(now())
  testInstances        TestInstance[]
  rule                 TestRule?
  sections             TestSection[]

  @@index([configKey])
}

model TestSection {
  id              String     @id @default(cuid())
  testConfigId    String
  sectionKey      String
  displayName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int
  testConfig      TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)

  @@index([testConfigId])
}

model TestRule {
  id               String     @id @default(cuid())
  testConfigId     String     @unique
  negativeMarking  Boolean    @default(false)
  sectionLocking   Boolean    @default(true)
  shuffleQuestions Boolean    @default(false)
  allowNavigation  Boolean    @default(false)
  testConfig       TestConfig @relation(fields: [testConfigId], references: [id], onDelete: Cascade)
}

model GeneratedQuestion {
  id              String          @id @default(cuid())
  templateId      String
  questionHash    String          @unique
  conceptKey      String
  difficultyLevel DifficultyLevel
  questionType    String
  questionText    String
  options         Json
  correctAnswer   Json
  solution        Json
  metadata        Json
  createdAt       DateTime        @default(now())
  template        Template        @relation(fields: [templateId], references: [id])

  @@index([conceptKey])
  @@index([difficultyLevel])
}

model TestInstance {
  id               String                 @id @default(cuid())
  userId           String
  testConfigId     String
  status           TestInstanceStatus     @default(CREATED)
  startedAt        DateTime?
  expiresAt        DateTime?
  submittedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  candidateAnswers CandidateAnswer[]
  evaluationResult EvaluationResult?
  executionState   ExecutionState?
  submission       Submission?
  testConfig       TestConfig             @relation(fields: [testConfigId], references: [id])
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions        TestInstanceQuestion[]
  sections         TestInstanceSection[]

  @@index([userId])
  @@index([status])
  @@index([testConfigId])
  @@index([createdAt])
}

model TestInstanceSection {
  id              String                 @id @default(cuid())
  testInstanceId  String
  sectionKey      String
  sectionName     String
  durationSeconds Int
  questionCount   Int
  orderIndex      Int
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  questions       TestInstanceQuestion[]
  testInstance    TestInstance           @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([testInstanceId, orderIndex])
  @@index([testInstanceId])
}

model TestInstanceQuestion {
  id               String              @id @default(cuid())
  testInstanceId   String
  sectionId        String
  questionId       String
  questionOrder    Int
  questionSnapshot Json
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  section          TestInstanceSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  testInstance     TestInstance        @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([sectionId, questionOrder])
  @@index([testInstanceId])
  @@index([sectionId])
  @@index([questionId])
}

model CandidateAnswer {
  id                String       @id @default(cuid())
  testInstanceId    String
  questionId        String
  answer            Json
  timeSpentSeconds  Int          @default(0)
  isMarkedForReview Boolean      @default(false)
  savedAt           DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  testInstance      TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@unique([testInstanceId, questionId])
  @@index([testInstanceId])
  @@index([questionId])
}

model ExecutionState {
  id                   String       @id @default(cuid())
  testInstanceId       String       @unique
  currentQuestionIndex Int          @default(0)
  remainingTimeSeconds Int
  lastActivityAt       DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  testInstance         TestInstance @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
}

model Submission {
  id             String           @id @default(cuid())
  testInstanceId String           @unique
  submittedAt    DateTime?
  submissionHash String?          @unique
  status         SubmissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  testInstance   TestInstance     @relation(fields: [testInstanceId], references: [id], onDelete: Cascade)

  @@index([testInstanceId])
  @@index([status])
}

model Recommendation {
  id           String                 @id @default(cuid())
  evaluationId String
  skill        String
  priority     RecommendationPriority
  title        String
  description  String
  createdAt    DateTime               @default(now())
  evaluation   EvaluationResult       @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([priority])
}

model PerformanceSummary {
  id                 String    @id @default(cuid())
  userId             String    @unique
  testsCompleted     Int       @default(0)
  averageScore       Float     @default(0.0)
  bestScore          Float     @default(0.0)
  lastAssessmentDate DateTime?
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamConfig {
  id                     String                  @id @default(cuid())
  name                   String
  role                   String
  durationMinutes        Int
  totalQuestions         Int
  isActive               Boolean                 @default(true)
  createdBy              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  code                   String                  @unique
  description            String?
  isArchived             Boolean                 @default(false)
  status                 ConfigStatus            @default(DRAFT)
  difficultyDistribution DifficultyDistribution?
  versions               ExamConfigVersion[]
  publishLogs            ConfigPublishLog[]
  ruleFlags              RuleFlags?
  sections               ExamSection[]
  blueprint              Blueprint?
  readinessReports       ReadinessReport[]

  @@index([createdAt])
  @@index([role])
  @@index([status])
}

model ExamSection {
  id                     String         @id @default(cuid())
  examConfigId           String
  name                   String
  questionCount          Int
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  code                   String
  isRequired             Boolean        @default(true)
  sectionDurationMinutes Int
  sectionOrder           Int
  examConfig             ExamConfig     @relation(fields: [examConfigId], references: [id], onDelete: Cascade)
  sectionTopics          SectionTopic[]

  blueprintTopicConfigs  BlueprintTopicConfig[]
  questions              Question[]

  @@unique([examConfigId, code])
  @@index([examConfigId])
  @@index([sectionOrder])
}

model DifficultyDistribution {
  id               String   @id @default(uuid())
  examConfigId     String   @unique
  easyPercentage   Int
  mediumPercentage Int
  hardPercentage   Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  examConfig ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}

model ExamConfigVersion {
  id            String     @id @default(cuid())
  examConfigId  String
  versionNumber Int
  snapshot      Json
  createdAt     DateTime   @default(now())
  examConfig    ExamConfig @relation(fields: [examConfigId], references: [id])

  @@unique([examConfigId, versionNumber])
  @@index([examConfigId])
}

model RuleFlags {
  id                         String   @id @default(uuid())
  examConfigId               String   @unique
  negativeMarkingEnabled     Boolean  @default(false)
  sectionalCutoffEnabled     Boolean  @default(false)
  adaptiveDifficultyEnabled  Boolean  @default(false)
  shuffleQuestionsEnabled    Boolean  @default(false)
  shuffleOptionsEnabled      Boolean  @default(false)
  allowSectionNavigation     Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  examConfig ExamConfig @relation(fields: [examConfigId], references: [id], onDelete: Cascade)

  @@index([examConfigId])
}

model Topic {
  id              String                 @id @default(uuid())
  name            String
  code            String                 @unique
  description     String?
  status          TopicStatus            @default(ACTIVE)
  concepts        Concept[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  sectionTopics   SectionTopic[]
  blueprintTopicConfigs BlueprintTopicConfig[]
  questions       Question[]
}

model Concept {
  id          String        @id @default(uuid())
  topicId     String
  name        String
  code        String
  description String?
  status      ConceptStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  topic       Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, code])
  @@index([topicId])
}

enum TopicStatus {
  ACTIVE
  INACTIVE
}

enum ConceptStatus {
  ACTIVE
  INACTIVE
}

model StyleProfile {
  id          String   @id @default(uuid())
  name        String
  profileType String   @map("profile_type")
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  characteristics StyleProfileCharacteristic[]
  blueprints      Blueprint[]

  @@map("style_profiles")
  @@index([profileType])
  @@index([active])
}

model StyleProfileCharacteristic {
  id                 String   @id @default(uuid())
  profileId          String   @map("profile_id")
  characteristicName String   @map("characteristic_name")
  characteristicValue Json     @map("characteristic_value")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  profile StyleProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, characteristicName])
  @@map("style_profile_characteristics")
  @@index([profileId])
}

model Blueprint {
  id             String   @id @default(uuid())
  configId       String   @unique @map("config_id")
  styleProfileId String   @map("style_profile_id")
  sections       Json     // Stored as BlueprintSection[] JSON
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  examConfig   ExamConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)
  styleProfile StyleProfile @relation(fields: [styleProfileId], references: [id], onDelete: Restrict)

  @@map("blueprints")
  @@index([configId])
  @@index([styleProfileId])
}

model SectionTopic {
  id        String   @id @default(cuid())
  sectionId String
  topicId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section        ExamSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  topic          Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicWeightage TopicWeightage?

  @@unique([sectionId, topicId])
  @@index([sectionId])
  @@index([topicId])
}

model TopicWeightage {
  id                  String   @id @default(cuid())
  sectionId           String
  topicId             String
  weightagePercentage Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sectionTopic        SectionTopic @relation(fields: [sectionId, topicId], references: [sectionId, topicId], onDelete: Cascade)

  @@unique([sectionId, topicId])
  @@index([sectionId])
  @@index([topicId])
}

enum UserRole {
  CANDIDATE
  ADMIN
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum TestStatus {
  DRAFT
  ONGOING
  COMPLETED
  EVALUATED
  FAILED
}

enum TestInstanceStatus {
  CREATED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  EVALUATED
}

enum RecommendationPriority {
  HIGH
  MEDIUM
  LOW
}

enum ConfigStatus {
  DRAFT
  VALIDATED
  ACTIVE
  PUBLISHED
  ARCHIVED
  VALIDATED
  PUBLISHED
}

model ConfigPublishLog {
  id          String     @id @default(cuid())
  configId    String
  publishedBy String?
  version     String
  publishedAt DateTime   @default(now())
  examConfig  ExamConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model BlueprintConfig {
  id                   String @id @default(uuid())
  name                 String
  code                 String @unique
  description          String?

  totalQuestions       Int
  totalDurationMinutes Int

  isActive             Boolean @default(true)

  topicConfigs         BlueprintTopicConfig[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  @@map("blueprint_configs")
  @@index([deletedAt])
}

model BlueprintTopicConfig {
  id            String @id @default(uuid())

  blueprintId   String
  sectionId     String
  topicId       String

  questionCount Int
  weightage     Decimal

  easyCount     Int
  mediumCount   Int
  hardCount     Int

  createdAt     DateTime @default(now())

  blueprint     BlueprintConfig @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  topic         Topic           @relation(fields: [topicId], references: [id], onDelete: Restrict)
  examSection   ExamSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([blueprintId, topicId])
  @@map("blueprint_topic_configs")
  @@index([blueprintId])
  @@index([sectionId])
  @@index([topicId])
}

enum VariableType {
  STRING
  NUMBER
  BOOLEAN
  ARRAY
  CODE
}

enum RuleType {
  DIFFICULTY
  RANGE
  LENGTH
  REGEX
}

model TemplateVariable {
  id           String       @id @default(uuid())
  templateId   String       @map("template_id")
  variableName String       @map("variable_name")
  variableType VariableType @map("variable_type")
  required     Boolean      @default(false)
  defaultValue String?      @map("default_value")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  template     Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, variableName])
  @@map("template_variables")
  @@index([templateId])
}

model TemplateRule {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  ruleType   RuleType @map("rule_type")
  ruleConfig Json     @map("rule_config")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_rules")
  @@index([templateId])
}

model SolutionTemplate {
  id                  String   @id @default(uuid())
  templateId          String   @unique @map("template_id")
  solutionTemplate    String   @map("solution_template")
  explanationTemplate String?  @map("explanation_template")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("solution_templates")
  @@index([templateId])
}

model TemplatePreview {
  id             String   @id @default(uuid())
  templateId     String   @map("template_id")
  previewPayload Json     @map("preview_payload")
  previewResult  Json     @map("preview_result")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_previews")
  @@index([templateId])
}

model ReadinessReport {
  id        String   @id @default(uuid())
  configId  String   @map("config_id")
  score     Int
  status    String   @db.VarChar(20)
  report    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  examConfig ExamConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("readiness_reports")
  @@index([configId])
}

enum QuestionStatus {
  DRAFT
  VALIDATED
  ACTIVE
  ARCHIVED
}

model Question {
  id              String         @id @default(cuid())
  questionText    String         @map("question_text")
  answer          String
  explanation     String
  topicId         String         @map("topic_id")
  sectionId       String         @map("section_id")
  difficulty      String         // "EASY", "MEDIUM", "HARD"
  difficultyScore Float?         @map("difficulty_score")
  source          String         // "GENERATED" | "MANUAL"
  templateId      String?        @map("template_id")
  version         Int            @default(1)
  status          QuestionStatus @default(DRAFT)
  timesUsed       Int            @default(0) @map("times_used")
  lastUsed        DateTime?      @map("last_used")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  topic           Topic          @relation(fields: [topicId], references: [id], onDelete: Restrict)
  section         ExamSection    @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  template        Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  versions        QuestionVersion[]
  reviews         QuestionReview[]
  reservations    QuestionReservation[]
  usage           QuestionUsage?

  @@map("questions")
  @@index([topicId])
  @@index([difficulty])
  @@index([templateId])
  @@index([status])
}

model QuestionVersion {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  version    Int
  snapshot   Json
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_versions")
  @@index([questionId])
  @@index([version])
}

model QuestionReview {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  status     String   // "APPROVED" | "REJECTED"
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_reviews")
  @@index([questionId])
}

model QuestionReservation {
  id         String   @id @default(cuid())
  questionId String   @unique @map("question_id")
  assemblyId String   @map("assembly_id")
  reservedAt DateTime @default(now()) @map("reserved_at")
  expiresAt  DateTime @map("expires_at")

  // Relations
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_reservations")
  @@index([assemblyId])
}

model QuestionUsage {
  id           String    @id @default(cuid())
  questionId   String    @unique @map("question_id")
  timesUsed    Int       @default(0) @map("times_used")
  lastUsed     DateTime? @map("last_used")
  sectionUsage Json      @default("{}") @map("section_usage")
  examUsage    Json      @default("{}") @map("exam_usage")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_usage")
  @@index([questionId])
}

model GenerationLog {
  id         String   @id @default(cuid())
  examId     String   @map("exam_id")
  sectionId  String?  @map("section_id")
  step       String   // "CONTEXT_RESOLVE", "TEMPLATE_SELECT", "PARAM_GEN", "INSTANTIATION", "VALIDATION"
  status     String   // "SUCCESS", "FAILED", "RETRYING"
  durationMs Int      @map("duration_ms")
  templateId String?  @map("template_id")
  retryCount Int      @map("retry_count")
  message    String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("generation_logs")
  @@index([examId])
  @@index([createdAt])
}

model ValidationLog {
  id             String   @id @default(cuid())
  questionId     String?  @map("question_id")
  validationStage String   @map("validation_stage") // "STRUCTURAL" | "TOPIC" | "DIFFICULTY" | "CONTRACT"
  isValid        Boolean  @map("is_valid")
  failureReason  String?  @map("failure_reason")
  retryTriggered Boolean  @map("retry_triggered")
  errors         Json     // array of strings
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("validation_logs")
  @@index([isValid])
  @@index([createdAt])
}

model GenerationAuditLog {
  id               String   @id @default(cuid())
  prompt           String
  response         String
  qualityScore     Float    @map("quality_score")
  validationResult Json     @map("validation_result")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("generation_audit_logs")
  @@index([createdAt])
}


