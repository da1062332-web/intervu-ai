{
  "$schema": "https://turbo.build/schema.json",

  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET"
  ],

  "tasks": {

    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },

    "lint": {
      "dependsOn": ["^build"]
    },

    "type-check": {
      "dependsOn": ["^build"]
    },

    "test": {
      "dependsOn": ["^test"]
    },

    "test:integration": {
      "dependsOn": ["build"]
    },

    "test:contracts": {
      "dependsOn": ["build"]
    },

    "test:regression": {
      "dependsOn": ["build"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}