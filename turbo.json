{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {

    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "type-check": {
      "dependsOn": ["^type-check"]
    },

    "test": {
      "dependsOn": ["^test"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}