{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "module": "commonjs",

    "declaration": true,

    "removeComments": true,

    "emitDecoratorMetadata": true,

    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "target": "ES2021",

    "sourceMap": true,

    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": "./",

    "incremental": true,

    "paths": {
      "@/*": ["src/*"],

      "@intervu-ai/shared-logger": ["../../packages/shared-logger/src"],
      "@intervu-ai/generation": ["../../generation/src"],
      "@intervu-ai/validation-core": ["../../packages/validation-core/src"]
    }
  },

  "include": ["src/**/*", "tests/**/*"],

  "exclude": ["node_modules", "dist"]
}
