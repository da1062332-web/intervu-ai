{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "module": "commonjs",

    "declaration": true,

    "removeComments": true,

    "emitDecoratorMetadata": true,

    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "target": "ES2021",

    "sourceMap": true,

    "outDir": "./dist",

    "baseUrl": "./",

    "incremental": true,

    "paths": {
      "@/*": ["src/*"],

      "@intervu-ai/shared-types": ["../../packages/shared-types/dist"],
      "@intervu-ai/shared-logger": ["../../packages/shared-logger/dist"]
    }
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
