# Environment variables for apps/api
# Copy this to .env in the same directory: cp .env.example .env

NODE_ENV=development
PORT=3000

# Database URL for PostgreSQL (assumes local Docker compose settings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intervu_ai

# Redis connection URL (assumes local Docker compose settings)
REDIS_URL=redis://localhost:6379

# JWT secrets (Must be at least 32 characters long)
JWT_SECRET=replace-with-a-long-secret-at-least-32-chars-long-012345
JWT_REFRESH_SECRET=replace-with-another-long-secret-at-least-32-chars-long-678910
