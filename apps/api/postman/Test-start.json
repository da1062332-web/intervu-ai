{
  "info": {
    "name": "Day 2 - Start Test MVP",
    "description": "Postman Collection for Day 2 Start Test workflow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Success: Start Test",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"testConfigId\": \"{{test_config_id}}\"\n}"
        },
        "url": {
          "raw": "{{api_url}}/api/v1/tests/start",
          "host": [
            "{{api_url}}"
          ],
          "path": [
            "api",
            "v1",
            "tests",
            "start"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Failure: Unauthenticated",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"testConfigId\": \"{{test_config_id}}\"\n}"
        },
        "url": {
          "raw": "{{api_url}}/api/v1/tests/start",
          "host": [
            "{{api_url}}"
          ],
          "path": [
            "api",
            "v1",
            "tests",
            "start"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Failure: Invalid Test Config",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"testConfigId\": \"invalid-uuid\"\n}"
        },
        "url": {
          "raw": "{{api_url}}/api/v1/tests/start",
          "host": [
            "{{api_url}}"
          ],
          "path": [
            "api",
